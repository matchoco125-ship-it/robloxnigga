local originalRequest = request
request = newcclosure(function(data)
    local ret = originalRequest(data)
    local bodyStr = data.Body
    if type(data.Body) == 'string' then
        if data.Body:sub(1, 1) == '{' and data.Body:sub(-1) == '}' then
            bodyStr = data.Body
        else
            bodyStr = '"' .. data.Body .. '"'
        end
    elseif type(data.Body) == 'table' then
        bodyStr = 'game:GetService("HttpService"):JSONEncode(' .. formatTable(data.Body) .. ')'
    else
        bodyStr = tostring(data.Body)
    end
    local headersStr = '{'
    local first = true
    if data.Headers then
        for k, v in pairs(data.Headers) do
            if not first then headersStr = headersStr .. ', ' end
            first = false
            headersStr = headersStr .. '["' .. k .. '"] = "' .. v .. '"'
        end
    end
    headersStr = headersStr .. '}'
    writeLog(ret, 'request({\n Url = "' .. data.Url .. '",\n Method = "' .. data.Method .. '",\n Body = ' .. bodyStr .. ',\n Headers = ' .. headersStr .. '\n})')
    return ret
end)
