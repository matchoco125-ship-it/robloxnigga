local mt = getrawmetatable(game)
local originalIndex = clonefunction(mt.__index)
local originalNamecall = clonefunction(mt.__namecall)
local originalNewIndex = clonefunction(mt.__newindex)
hookmetamethod(game, '__index', newcclosure(function(self, key, ...)
    if checkcaller() and not isUILibrary() then
        local ret = originalIndex(self, key, ...)
        local formatted = formatTable(...)
        if key == 'Character' then
            writeLog('LocalPlayer.Character', self:GetFullName() .. '.' .. key)
            return ret
        end
        local skipKeys = {
            GetService = true, HttpGet = true, JSONDecode = true, CoreGui = true,
            JSONEncode = true, WaitForChild = true, FindFirstChild = true, DescendantRemoving = true
        }
        if skipKeys[key] then return ret end
        if key == 'JobId' or key == 'PlaceId' then
            writeLog('game.' .. key, self:GetFullName() .. '.' .. key)
            return ret
        end
        if tostring(ret):find('function:') then
            writeLog(ret, self:GetFullName() .. ':' .. key .. '(' .. formatted .. ')')
            return ret
        end
        writeLog(ret, self:GetFullName() .. '.' .. key)
        return ret
    end
    return originalIndex(self, key, ...)
end))
hookmetamethod(game, '__namecall', newcclosure(function(self, ...)
    if checkcaller() and not isUILibrary() and getnamecallmethod() ~= 'GetFullName' then
        local instanceStr = tostring(self)
        if type(instanceStr) == 'Instance' then
            instanceStr = originalNamecall(instanceStr, 'GetFullName')
        end
        local ret = originalNamecall(self, ...)
        local args = {...}
        local formatted = formatTable(args)
        local method = getnamecallmethod()
        if method == 'GetService' then
            writeLog(ret, 'game:GetService("' .. args[1] .. '")')
            return ret
        end
        if method == 'WaitForChild' then
            writeLog(ret, instanceStr .. ':WaitForChild("' .. args[1] .. '")')
            return ret
        end
        if method == 'FindFirstChild' then
            writeLog(ret, instanceStr .. ':FindFirstChild("' .. args[1] .. '")')
            return ret
        end
        if method == 'HttpGet' then
            writeLog(ret, 'game:HttpGet("' .. args[1] .. '", true)')
            return ret
        end
        writeLog(ret, instanceStr .. ':' .. method .. '("' .. formatted .. '")')
        return ret
    end
    return originalNamecall(self, ...)
end))
hookmetamethod(game, '__newindex', newcclosure(function(self, key, value)
    if checkcaller() and not isUILibrary() then
        local ret = originalNewIndex(self, key, value)
        local cached = trackedInstances[self]
        local keyStr = tostring(key)
        local valType = tostring(typeof(value)) or 'Unknown'
        local valStr = tostring(value)
        local prefix = cached and (cached .. '.') or 'a.'
        if keyStr then
            if valType == 'Instance' then
                writeLog(ret, prefix .. keyStr .. ' = ' .. value:GetFullName())
            elseif valType == 'number' or valType == 'boolean' then
                writeLog(ret, prefix .. keyStr .. ' = ' .. valStr)
