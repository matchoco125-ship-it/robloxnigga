                writeLog(ret, prefix .. keyStr .. ' = "' .. valStr .. '"')
            elseif valType == 'Color3' then
                writeLog(ret, prefix .. keyStr .. ' = Color3.new(' .. valStr .. ')')
            elseif valType == 'CFrame' then
                writeLog(ret, prefix .. keyStr .. ' = CFrame.new(' .. valStr .. ')')
            elseif valType == 'Vector3' then
                writeLog(ret, prefix .. keyStr .. ' = Vector3.new(' .. valStr .. ')')
            elseif valType == 'UDim2' then
                writeLog(ret, prefix .. keyStr .. ' = UDim2.new(' .. valStr:gsub('{', ''):gsub('}', '') .. ')')
            elseif valType == 'Vector2' then
                writeLog(ret, prefix .. keyStr .. ' = Vector2.new(' .. valStr .. ')')
            elseif valType == 'UDim' then
                writeLog(ret, prefix .. keyStr .. ' = UDim.new(' .. valStr .. ')')
