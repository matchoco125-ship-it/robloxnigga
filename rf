local function isUILibrary()
    local trace = debug.traceback():lower():gsub('%s+', '')
    return trace:find('windui') or trace:find('rayfield') or trace:find('obsidian') or
           trace:find('interface') or trace:find('luna') or trace:find('fluent') or trace:find('drday')
end
local function formatLog(text)
    if type(text) ~= 'string' then
        error('Bad argument #1 to formatLog "string" expected, got: ' .. type(text))
    end
    return text:gsub('table: ', ''):gsub('function: ', ''):gsub('Ugc', 'game'):gsub('\n', ''):gsub('%s%s+', ';'):gsub('""', ''):gsub('Data Ping', 'DataPing'):gsub('Workspace', 'workspace'):gsub('game.Players', 'Players'):gsub('Teleport Service', 'TeleportService'):gsub('Run Service', 'RunService'):gsub('HttpGetAsync', 'HttpGet'):gsub('"', "'")
end
local function formatTable(tbl, depth)
    depth = depth or 0
    local res = ''
    local first = true
    if depth > 5 then return 'too big to display' end
    if type(tbl) ~= 'table' then
        res = '"' .. tostring(tbl) .. '"'
        if res == '"nil"' then res = '' end
        return res
    end
    for k, v in pairs(tbl) do
        if not first then res = res .. ', ' end
        first = false
        if type(k) == 'string' then res = res .. k .. ' = ' end
        if type(k) == 'table' then
            res = res .. formatTable(v, depth + 1)
        else
            res = res .. tostring(v)
        end
    end
    return res .. ''
end
local trackedInstances = {}
local loggedKeys = {}
local function makeKey(fem, boy) return fem .. ';' .. boy end
local lastLog = ''
local lastUpval = ''
local lastFormatted = ''
local logLineCount = 1
local function writeLog(upvalue, ...)
    upvalue = upvalue or 'nil'
    upvalue = formatLog(tostring(upvalue))
    if #upvalue > 100 then
        local len = #upvalue
        upvalue = upvalue:sub(1, 50) .. '... (' .. len .. ' characters remaining)'
    end
    local formatted = formatLog(tostring(...))
    local logged = formatted
    if logged == lastLog then return end
    if formatted == lastFormatted and upvalue == lastUpval then return end
    local key = makeKey(logged, upvalue)
    if loggedKeys[key] then return end
    if upvalue:find('Signal') then
        logged = formatted .. ':Connect(function(...)end)'
    end
    if logged:find('game:HttpGet') then
        logged = 'loadstring(' .. formatted .. ')()'
    end
    if logLineCount > 36000 then
        game:shutdown()
        return
    end
    if logged:find('IsA') then return end
    logLineCount = logLineCount + 1
    lastLog = logged
    lastUpval = upvalue
    lastFormatted = formatted
    loggedKeys[key] = true
    appendfile('logged.txt', logged .. '\n')
end
