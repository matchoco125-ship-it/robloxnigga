local function setMode(mobile)
	isMobileMode = mobile

	if mobile then
		modeButton.Text = "MOB"
		keyCard.Visible = false
		tapCard.Visible = true
	else
		modeButton.Text = "PC"
		keyCard.Visible = true
		tapCard.Visible = false
	end

	savedConfig.mobileMode = isMobileMode
	savedConfig.mainPosition = udim2ToTable(main.Position)
	saveVampireConfig()
end

local resetDebounce = false

local function pressEffect()
	if resetDebounce then return end
	resetDebounce = true

	vampireInstaReset()

	if not isMobileMode then
		ready.Text = "Reseting..."
		ready.TextColor3 = RED
		ready.TextTransparency = 0
		dot.BackgroundColor3 = Color3.fromRGB(255, 75, 70)
		rButton.TextColor3 = RED
	else
		tapCard.Text = "RESETING..."
		tapCard.TextColor3 = RED
		tapCard.TextTransparency = 0
	end

	task.delay(0.6, function()
		if ready then
			ready.Text = "Ready"
			ready.TextColor3 = GREY
			ready.TextTransparency = 0.16
		end

		if dot then
			dot.BackgroundColor3 = RED
		end

		if rButton then
			rButton.TextColor3 = WHITE
		end

		if tapCard then
			tapCard.Text = "TAP TO RESET"
			tapCard.TextColor3 = RED
			tapCard.TextTransparency = 0.04
		end

		resetDebounce = false
	end)
end

