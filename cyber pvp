local resetRemote = nil
local instaResetCooldown = false
local INSTA_RESET_GUID = "f888ee6e-c86d-46e1-93d7-0639d6635d42"

pcall(function()
    if hookfunction and newcclosure then
        local probe = Instance.new("RemoteEvent")
