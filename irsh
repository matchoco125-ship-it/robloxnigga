        for _,row in pairs(Pages["Protect"]:GetChildren()) do
            if row:IsA("Frame") then
                local lbl=row:FindFirstChild("TextLabel")
                if lbl and lbl.Text=="Auto Play" then
                    local tglBg=row:FindFirstChild("Frame")
